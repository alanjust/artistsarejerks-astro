---
import HiddenGrammarLayout from '../../../layouts/HiddenGrammarLayout.astro';
import { toolkitBuckets } from '../../../data/toolkit-modes.js';

const making = toolkitBuckets.find(b => b.id === 'making')!;
const analyzing = toolkitBuckets.find(b => b.id === 'analyzing')!;

const liveMaking = making.modes.filter(m => m.status === 'live');
const liveAnalyzing = analyzing.modes.filter(m => m.status === 'live');
---

<HiddenGrammarLayout
  title="For Working Artists"
  description="Studio tools for working artists — mid-process reads, attention engineering, structural diagnostics."
>
  <div class="hg-page fp-page">

    <header class="fp-header">
      <a href="/hidden-grammar" class="fp-back">← Art Lab</a>
      <h1 class="fp-title">For working artists</h1>
      <p class="fp-lead">You're mid-process, or you just finished something, and you want to know what it's actually doing — not what it means, but what it's doing. Where the eye goes. What's holding and what's sliding past.</p>
      <p class="fp-lead">That's a different question than most feedback gives you. Here's what's ready to use.</p>
    </header>

    <!-- Making tools -->
    <section class="fp-section">
      <div class="fp-section-header">
        <h2 class="fp-section-title">While you're making it</h2>
        <p class="fp-section-desc">Mid-process tools. Something's off, you're stuck, or you want to know where you actually are before you decide what to do next.</p>
      </div>
      <div class="fp-grid">
        {liveMaking.map(mode => {
          const href = mode.link || `/hidden-grammar/modes/${mode.id}`;
          return (
            <a href={href} class="fp-card">
              <span class="fp-card-label">{mode.label}</span>
              <p class="fp-card-tagline">{mode.tagline}</p>
              <span class="fp-card-cta">Use this tool →</span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Analyzing tools -->
    <section class="fp-section">
      <div class="fp-section-header">
        <h2 class="fp-section-title">When you want a structural read</h2>
        <p class="fp-section-desc">For finished work — yours or anyone else's. Grounded in what's visually observable, not in what the art world has decided it means.</p>
      </div>
      <div class="fp-grid">
        {liveAnalyzing.map(mode => {
          const href = mode.link || `/hidden-grammar/modes/${mode.id}`;
          return (
            <a href={href} class="fp-card">
              <span class="fp-card-label">{mode.label}</span>
              <p class="fp-card-tagline">{mode.tagline}</p>
              <span class="fp-card-cta">Use this tool →</span>
            </a>
          );
        })}
      </div>
    </section>

    <div class="fp-footer">
      <a href="/hidden-grammar/toolkit" class="fp-all-link">See all tools, including what's in development →</a>
    </div>

  </div>
</HiddenGrammarLayout>

<style>
  .fp-page {
    max-width: 900px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .fp-back {
    display: inline-block;
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .fp-back:hover {
    color: #334155;
  }

  .fp-header {
    margin-bottom: 3rem;
  }

  .fp-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1.25rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .fp-lead {
    font-size: 1.0625rem;
    color: #334155;
    line-height: 1.8;
    margin: 0 0 0.875rem;
    max-width: 680px;
  }

  .fp-section {
    margin-bottom: 3rem;
  }

  .fp-section-header {
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .fp-section-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.375rem;
  }

  .fp-section-desc {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0;
    line-height: 1.6;
  }

  .fp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1rem;
  }

  .fp-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.375rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-left: 3px solid #7c3aed;
    border-radius: 0 10px 10px 0;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .fp-card:hover {
    border-color: #7c3aed;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .fp-card-label {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
  }

  .fp-card-tagline {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .fp-card-cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #6d28d9;
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  .fp-footer {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .fp-all-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
  }

  .fp-all-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .fp-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
