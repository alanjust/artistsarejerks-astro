---
import HiddenGrammarLayout from '../../../layouts/HiddenGrammarLayout.astro';
import { toolkitBuckets } from '../../../data/toolkit-modes.js';

const talking = toolkitBuckets.find(b => b.id === 'talking');
---

<HiddenGrammarLayout
  title="For Educators, Docents, and Presenters"
  description="Art Lab tools for educators, docents, museum guides, and anyone who needs to make art accessible to a general audience."
>
  <div class="hg-page fp-page">

    <header class="fp-header">
      <a href="/hidden-grammar" class="fp-back">← Art Lab</a>
      <h1 class="fp-title">For educators, docents, and presenters</h1>
      <p class="fp-lead">You're standing in front of a work — or you will be, next Thursday, with a group of people who didn't necessarily choose to be there. You need something concrete to point at. Not interpretation. Not art-speak. Something you can actually say.</p>
      <p class="fp-lead">These tools are built specifically for that occasion.</p>
    </header>

    <section class="fp-section">
      <div class="fp-section-header">
        <h2 class="fp-section-title">Tools for talking about art to other people</h2>
        <p class="fp-section-desc">Structured outputs you can use in front of a room — docent scripts, critique frameworks for students, wall text, and spoken monologues grounded in what's visually observable.</p>
      </div>
      <div class="fp-grid">
        {talking.modes.map(mode => {
          const isLive = mode.status === 'live';
          const href = isLive ? (mode.link || `/hidden-grammar/modes/${mode.id}`) : null;

          return isLive ? (
            <a href={href} class="fp-card fp-card--live">
              <span class="fp-card-label">{mode.label}</span>
              <p class="fp-card-tagline">{mode.tagline}</p>
              <span class="fp-card-cta">Use this tool →</span>
            </a>
          ) : (
            <div class="fp-card fp-card--soon">
              <div class="fp-card-top">
                <span class="fp-card-label">{mode.label}</span>
                <span class="fp-badge-soon">Coming soon</span>
              </div>
              <p class="fp-card-tagline">{mode.tagline}</p>
            </div>
          );
        })}
      </div>
    </section>

    <div class="fp-footer">
      <a href="/hidden-grammar/toolkit" class="fp-all-link">Browse all Art Lab tools →</a>
    </div>

  </div>
</HiddenGrammarLayout>

<style>
  .fp-page {
    max-width: 900px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .fp-back {
    display: inline-block;
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .fp-back:hover {
    color: #334155;
  }

  .fp-header {
    margin-bottom: 3rem;
  }

  .fp-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1.25rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .fp-lead {
    font-size: 1.0625rem;
    color: #334155;
    line-height: 1.8;
    margin: 0 0 0.875rem;
    max-width: 680px;
  }

  .fp-section {
    margin-bottom: 3rem;
  }

  .fp-section-header {
    margin-bottom: 1.25rem;
    padding-bottom: 0.875rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .fp-section-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.375rem;
  }

  .fp-section-desc {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0;
    line-height: 1.6;
  }

  .fp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1rem;
  }

  .fp-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.375rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-left: 3px solid #059669;
    border-radius: 0 10px 10px 0;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .fp-card--live:hover {
    border-color: #059669;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .fp-card--soon {
    opacity: 0.65;
  }

  .fp-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .fp-card-label {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
  }

  .fp-card-tagline {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .fp-card-cta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #047857;
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  .fp-badge-soon {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .fp-footer {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .fp-all-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
  }

  .fp-all-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .fp-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
