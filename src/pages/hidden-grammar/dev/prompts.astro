---
export const prerender = false;
import HiddenGrammarLayout from '../../../layouts/HiddenGrammarLayout.astro';
import { basePrompt, interrogationBase, analysisModes } from '../../../data/analysisModes.js';
---

<HiddenGrammarLayout
  title="Prompt Registry"
  description="Complete prompt inventory for all Art Lab modes."
>
  <div class="hg-page dev-page prompt-registry">

    <div class="dev-header">
      <p class="dev-eyebrow">Internal — not public-facing</p>
      <h1>Prompt Registry</h1>
      <p class="dev-desc">Complete text of every prompt in the system. basePrompt and interrogationBase run on every analysis. Mode prompts run on top of them. Use Ctrl+F to find any prompt by ID, label, or content.</p>
    </div>

    <nav class="prompt-nav">
      <a href="#base-prompt">Base Prompt</a>
      <a href="#interrogation-base">Interrogation Base</a>
      {analysisModes.map(mode => (
        <a href={`#${mode.id}`}>{mode.label}{mode.internal ? ' (internal)' : ''}</a>
      ))}
    </nav>

    <section class="prompt-section" id="base-prompt">
      <div class="prompt-section-header">
        <h2>Base Prompt</h2>
        <span class="prompt-badge prompt-badge--system">System — always runs</span>
      </div>
      <p class="prompt-meta">Prepended to every analysis regardless of mode, sub-mode, or prompt. Cannot be overridden.</p>
      <pre class="prompt-text">{basePrompt}</pre>
    </section>

    <section class="prompt-section" id="interrogation-base">
      <div class="prompt-section-header">
        <h2>Interrogation Base</h2>
        <span class="prompt-badge prompt-badge--system">System — always runs</span>
      </div>
      <p class="prompt-meta">Appended to every follow-up question in the interrogation window. Cannot be overridden.</p>
      <pre class="prompt-text">{interrogationBase}</pre>
    </section>

    {analysisModes.map(mode => (
      <section class="prompt-section" id={mode.id}>
        <div class="prompt-section-header">
          <h2>{mode.label}</h2>
          {mode.internal && <span class="prompt-badge prompt-badge--internal">Internal</span>}
          <span class="prompt-meta-inline">ID: {mode.id}</span>
        </div>
        <p class="prompt-meta">{mode.description}</p>

        {mode.prompts.length === 0 && (
          <p class="prompt-empty">No prompts defined. This mode uses a dedicated page.</p>
        )}

        {mode.prompts.map(p => (
          <div class="prompt-entry" id={p.id}>
            <div class="prompt-entry-header">
              <h3>{p.label}</h3>
              <span class="prompt-meta-inline">ID: {p.id}</span>
            </div>
            <p class="prompt-entry-desc">{p.description}</p>
            <pre class="prompt-text">{p.prompt}</pre>
          </div>
        ))}
      </section>
    ))}

  </div>
</HiddenGrammarLayout>

<style>
  .prompt-registry {
    max-width: 820px;
  }

  .prompt-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 0.75rem;
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 6px;
  }

  .prompt-nav a {
    font-size: 0.75rem;
    font-weight: 600;
    color: #92400e;
    text-decoration: none;
    white-space: nowrap;
  }

  .prompt-nav a:hover {
    text-decoration: underline;
  }

  .prompt-section {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .prompt-section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.375rem;
  }

  .prompt-section-header h2 {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .prompt-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
    border: 1px solid;
    white-space: nowrap;
  }

  .prompt-badge--system {
    background: #f0fdf4;
    color: #166534;
    border-color: #bbf7d0;
  }

  .prompt-badge--internal {
    background: #fef3c7;
    color: #92400e;
    border-color: #fde68a;
  }

  .prompt-meta {
    font-size: 0.875rem;
    color: #64748b;
    margin: 0 0 1rem 0;
    line-height: 1.5;
  }

  .prompt-meta-inline {
    font-size: 0.6875rem;
    color: #94a3b8;
    font-family: monospace;
  }

  .prompt-entry {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed #e2e8f0;
  }

  .prompt-entry-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .prompt-entry-header h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #334155;
    margin: 0;
  }

  .prompt-entry-desc {
    font-size: 0.8125rem;
    color: #64748b;
    margin: 0 0 0.75rem 0;
  }

  .prompt-text {
    font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
    font-size: 0.75rem;
    line-height: 1.65;
    color: #334155;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
    overflow-x: auto;
  }

  .prompt-empty {
    font-size: 0.875rem;
    color: #94a3b8;
    font-style: italic;
    margin: 0;
  }
</style>
