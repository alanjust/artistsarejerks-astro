    background: #16a34a;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .al-try-me-btn:hover {
    background: #15803d;
    transform: translateY(-1px);
  }

  .al-try-me-label {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .al-try-me-sub {
    font-size: 1rem;
    font-weight: 500;
    color: #bbf7d0;
    letter-spacing: 0.01em;
  }

  .al-start-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    padding: 1rem 2rem;
    background: transparent;
    border: 2px solid #16a34a;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .al-start-btn:hover {
    background: #f0fdf4;
    transform: translateY(-1px);
  }

  .al-start-label {
    font-size: 1.25rem;
    font-weight: 700;
    color: #16a34a;
    letter-spacing: -0.01em;
  }

  .al-section-rule {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }

  /* ── Map note ──────────────────────────────── */
  .al-map-note {
    font-size: 1.0rem;
    font-weight: 500;
    font-style: italic;
    color: #16a34a;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  /* ── Persona cards ─────────────────────────── */
  .al-personas {
    margin-top: 2.5rem;
  }

  .al-personas-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.375rem;
  }

  .al-personas-intro {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .al-persona-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .al-persona-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1.25rem 1.375rem;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    background: #ffffff;
  }

  .al-persona-card:hover {
    border-color: #94a3b8;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .al-persona-card--artist  { border-left: 3px solid #7c3aed; }
  .al-persona-card--edu     { border-left: 3px solid #059669; }
  .al-persona-card--curious { border-left: 3px solid #d97706; }

  .al-persona-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
  }

  .al-persona-card--artist  .al-persona-label { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-label { color: #047857; }
  .al-persona-card--curious .al-persona-label { color: #b45309; }

  .al-persona-body {
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .al-persona-body:last-of-type {
    margin-bottom: 0.875rem;
  }

  .al-persona-cta {
    font-size: 0.875rem;
    font-weight: 600;
    align-self: flex-start;
  }

  .al-persona-card--artist  .al-persona-cta { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-cta { color: #047857; }
  .al-persona-card--curious .al-persona-cta { color: #b45309; }

  /* ── Caution ───────────────────────────────── */
  .al-caution {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid #f59e0b;
    border-radius: 0 10px 10px 0;
  }

  .al-caution-title {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #92400e;
    margin: 0 0 0.875rem;
  }

  .al-caution-body {
    font-size: 0.9375rem;
    color: #78350f;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }

  .al-caution-link {
    color: #92400e;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .al-caution-link:hover {
    text-decoration: underline;
  }

  .al-caution-kicker {
    font-size: 0.9375rem;
    font-weight: 700;
    font-style: italic;
    color: #92400e;
    margin: 0;
  }

  /* ── Sidebar (right column) ────────────────── */
  .al-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .al-sidebar-card {
    border-radius: 10px;
    padding: 1.25rem 1.375rem;
  }

  .al-sidebar-card-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.875rem;
  }

  .al-sidebar-reading {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }

  .al-reading-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .al-reading-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #4f46e5;
    text-decoration: none;
    line-height: 1.4;
  }

  .al-reading-link:hover {
    text-decoration: underline;
  }

  /* ── Section cards — full width ────────────── */
  .al-sections {
    width: 100%;
  }

  .al-sections-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .al-sections-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .al-sections-grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .al-section-card {
    min-height: 200px;
  }

  .al-section-card--soon {
    opacity: 0.75;
    pointer-events: none;
  }

  .al-section-card--soon:hover {
    border-color: #e2e8f0;
    box-shadow: none;
    transform: none;
  }

  .al-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .al-badge-soon {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .al-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
  }

  .al-card-arrow {
    font-size: 0.875rem;
    color: #4f46e5;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    transform: translateX(-4px);
  }

  .hg-card:hover .al-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .al-card-arrow-soon {
    font-size: 0.875rem;
    font-weight: 600;
    color: #94a3b8;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .al-body {
      grid-template-columns: 1fr;
    }

    .al-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .al-sidebar-card {
      flex: 1 1 280px;
    }

    /* Tablet: 2-up persona cards */
    .al-persona-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .al-sections-grid {
      grid-template-columns: 1fr;
    }

    .al-caution {
      padding: 1.25rem;
    }

    .al-sidebar {
      flex-direction: column;
    }

    /* Mobile: single column persona cards */
    .al-persona-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
