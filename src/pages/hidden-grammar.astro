  }

  .al-sidebar-why p {
    color: #3730a3;
  }

  .al-sidebar-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
  }

  .al-sidebar-link:hover {
    text-decoration: underline;
  }

  .al-sidebar-caution {
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid #f59e0b;
  }

  .al-sidebar-caution .al-sidebar-card-title {
    color: #92400e;
  }

  .al-sidebar-caution p {
    color: #78350f;
  }

  .al-sidebar-kicker {
    font-weight: 700;
    font-style: italic;
  }

  /* ── Section cards — full width ────────────── */
  .al-sections {
    width: 100%;
  }

  .al-sections-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .al-sections-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .al-sections-grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .al-section-card {
    min-height: 200px;
  }

  .al-section-card--soon {
    opacity: 0.75;
    pointer-events: none;
  }

  .al-section-card--soon:hover {
    border-color: #e2e8f0;
    box-shadow: none;
    transform: none;
  }

  .al-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .al-badge-soon {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .al-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
  }

  .al-card-arrow {
    font-size: 0.875rem;
    color: #4f46e5;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    transform: translateX(-4px);
  }

  .hg-card:hover .al-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .al-card-arrow-soon {
    font-size: 0.875rem;
    font-weight: 600;
    color: #94a3b8;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
