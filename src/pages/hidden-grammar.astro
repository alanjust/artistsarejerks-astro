---
import HiddenGrammarLayout from '../layouts/HiddenGrammarLayout.astro';

const sections = [
  {
    id: 'toolkit',
    label: 'Analysis Tools',
    title: 'Toolkit',
    description: "The primary way to use Art Lab. Pick what you're trying to do — making, analyzing, teaching, or stress-testing — and find the right tool for it.",
    status: 'live',
    href: '/hidden-grammar/toolkit',
    cta: 'Open the Toolkit →',
  },
  {
    id: 'framework',
    label: 'Framework',
    title: 'Hidden Grammar Framework',
    description: 'The structural system behind the analysis — what the 11 Roots, 54 Principles, and 4 Poles are, how they connect, and why the framework is built this way.',
    status: 'live',
    href: '/hidden-grammar/framework',
    cta: 'Explore the Framework →',
  },
  {
    id: 'roots',
    label: 'Framework',
    title: '11 Hidden Grammar Roots',
    description: 'The structural categories that organize all 54 Principles. Design Logic, Tactile Execution, Structural Integrity, Atmosphere, and seven more.',
    status: 'coming-soon',
    href: '/hidden-grammar/roots',
    cta: 'Explore the Roots →',
  },
  {
    id: 'principles',
    label: 'Framework',
    title: '54 Art Principles',
    description: 'The complete inventory of perceptual and compositional mechanisms the framework uses. Each Principle maps to a Root and a neural mechanism.',
    status: 'live',
    href: '/hidden-grammar/principles',
    cta: 'Browse the Principles →',
  },
  {
    id: 'poles',
    label: 'Framework',
    title: 'The 4 Poles',
    description: 'The four opposing forces that create visual tension in any work. Understanding the Poles tells you where a work sits on each axis.',
    status: 'coming-soon',
    href: '/hidden-grammar/poles',
    cta: 'See the Poles →',
  },
  {
    id: 'lenses',
    label: 'External Frameworks',
    title: 'Interrogation Lenses',
    description: '24 critical and philosophical frameworks — from Object-Oriented Ontology to Hauntology — applied as analytical overlays on any analysis.',
    status: 'live',
    href: '/hidden-grammar/lenses',
    cta: 'Browse the Lenses →',
  },
  {
    id: 'reference',
    label: 'Reference',
    title: 'Reference Materials',
    description: "The Feldman Four-Step Critique, Visual Arts Standards, and the Master Project Bible. Foundational documents the framework builds on.",
    status: 'coming-soon',
    href: '/hidden-grammar/reference',
    cta: 'Open Reference →',
  },
];
---

<HiddenGrammarLayout
  title="Art Lab"
  description="Structured tools for looking at art — grounded in what's visually observable, not in what the art world has decided it means."
>
  <div class="hg-page">

    <!-- ── TOP: INTRO + SIDEBAR ────────────────────────────── -->
    <div class="al-body">

      <!-- Left: intro content -->
      <div class="al-intro">
        <h1 class="al-intro-title">Art Lab</h1>

        <p class="al-intro-kicker">Tools for looking at art. Starting with what you can actually see.</p>

        <!-- Flow diagram -->
        <div class="al-flow">
          <p class="al-flow-label">huh?</p>
          <div class="al-flow-steps">
            <div class="al-flow-node al-flow-node--image">
              <span class="al-flow-node-top">your image</span>
            </div>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--upload">
              <span class="al-flow-node-top">upload it</span>
              <span class="al-flow-node-zone">drop here</span>
            </div>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--analyze">
              <span class="al-flow-node-btn">Analyze</span>
            </div>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--results">
              <span class="al-flow-node-top">analysis</span>
              <span class="al-flow-node-line"></span>
              <span class="al-flow-node-line al-flow-node-line--short"></span>
            </div>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--question">
              <span class="al-flow-node-input">why does the eye go there?</span>
            </div>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--results">
              <span class="al-flow-node-top">more</span>
              <span class="al-flow-node-line"></span>
              <span class="al-flow-node-line al-flow-node-line--short"></span>
            </div>
            <span class="al-flow-arrow al-flow-arrow--loop">↺ keep going</span>
            <span class="al-flow-arrow">→</span>
            <div class="al-flow-node al-flow-node--copy">
              <span class="al-flow-node-btn al-flow-node-btn--copy">Copy</span>
            </div>
          </div>
        </div>

        <div class="al-try-me">
          <a href="/hidden-grammar/ai-analyze?mode=first-look&prompt=first-look-read" class="al-try-me-btn">
            <span class="al-try-me-label">Try Me</span>
            <span class="al-try-me-sub">upload anything</span>
          </a>
          <a href="/hidden-grammar/start" class="al-start-btn">
            <span class="al-start-label">Start Analyzing</span>
          </a>
        </div>

        <p class="al-map-note">You're uploading a photo. The physical work of the original—its scale, surface, and material weight—doesn't come through. The analysis is real, but it's working from a reduced signal. A map, not the territory.</p>

        <div class="al-section-rule"></div>

        <!-- Field guide -->
        <p class="al-intro-body">Think about the last time a painting stopped you. Not a painting you understood — one that stopped you before you knew why. Something happened. You just don't know what.</p>

        <p class="al-intro-body">That's the question Art Lab is built to answer.</p>

        <p class="al-intro-body">Upload an image — yours, someone else's, something you photographed at a museum and couldn't shake — and what comes back isn't interpretation. It's a structural read of what the work is actually doing to the eye in the first seconds of contact. Which edges are pulling attention. Where the eye moves and where it stalls. What the visual system is predicting, and whether the work confirms or violates that prediction.</p>

        <p class="al-intro-body">So here's what that looks like in practice. A painter finds out why the eye keeps going to the wrong corner. A museum visitor gets language for what's happening in an encounter they couldn't name. A comic artist learns whether their visual register is reading the way they intend for the market they're targeting.</p>

        <p class="al-intro-body">The framework running underneath all of this is called Hidden Grammar — fifty-four perceptual mechanisms describing how visual communication works at the level of the nervous system, before culture, before taste, before any of the interpretive frameworks we usually reach for. The tools run that framework against whatever you put in front of them.</p>

        <p class="al-intro-body">What comes back is usually surprising.</p>

        <div class="al-section-rule"></div>


        <!-- Caution -->
        <div class="al-caution">
          <h2 class="al-caution-title">One thing before you pick a tool</h2>
          <p class="al-caution-body">Art Lab makes things legible that were previously invisible. That's useful. It can also, if you're not careful, turn creating into a performance review.</p>
          <p class="al-caution-body">If you're here to see your choices more clearly—to tighten, strengthen, understand what's working—it's for you. But if creating is mostly about pleasure or flow or finding your way, be careful. Once you start measuring, it's hard to stop. The measuring can become the point.</p>
          <p class="al-caution-body">Some artists will call this reductive. They're not wrong—any analysis reduces a work. The question is whether what remains after the reduction is useful to you.</p>
          <a href="/hidden-grammar/analysis-worth" class="al-text-link al-caution-link">Does analysis destroy an artwork? The full answer →</a>
          <p class="al-caution-kicker">Know what you came for.</p>
        </div>

      </div>

      <!-- Right: sidebar -->
      <aside class="al-sidebar">

        <div class="al-sidebar-card al-sidebar-reading">
          <h2 class="al-sidebar-card-title">Reading</h2>
          <ul class="al-reading-list">
            <li><a href="/hidden-grammar/why" class="al-reading-link">Why I built this</a></li>
            <li><a href="/hidden-grammar/keeping-score" class="al-reading-link">A different way to keep score</a></li>
            <li><a href="/hidden-grammar/grammar" class="al-reading-link">The grammar of visual art</a></li>
          </ul>
        </div>

      </aside>

    </div>

    <!-- ── SECTION CARDS — full width below ──────────────── -->
    <div class="al-sections">
      <div class="al-sections-header">
        <h2 class="al-sections-title">What's in Art Lab</h2>
      </div>
      <div class="hg-grid al-sections-grid">
        {sections.map(section => (
          section.status === 'live' ? (
            <a href={section.href} class="hg-card al-section-card">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span></span>
                <span class="al-card-arrow">→</span>
              </div>
            </a>
          ) : (
            <div class="hg-card al-section-card al-section-card--soon">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
                <span class="al-badge-soon">Coming soon</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span class="al-card-arrow-soon">{section.cta}</span>
              </div>
            </div>
          )
        ))}
      </div>
    </div>

  </div>
</HiddenGrammarLayout>

<style>
  /* ── Two-column top: intro + sidebar ──────── */
  .al-body {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  /* ── Intro (left column) ───────────────────── */
  .al-intro {
    min-width: 0;
  }

  .al-intro-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .al-intro-kicker {
    font-size: 1.25rem;
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #b45309;
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .al-intro-body {
    font-size: 1.0625rem;
    color: #334155;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .al-text-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .al-text-link:hover {
    text-decoration: underline;
  }

  /* ── Flow diagram ───────────────────────────── */
  .al-flow {
    margin: 1.5rem 0 1.25rem;
  }

  .al-flow-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.625rem;
  }

  .al-flow-steps {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    row-gap: 0.5rem;
  }

  .al-flow-arrow {
    font-size: 0.875rem;
    color: #cbd5e1;
    flex-shrink: 0;
  }

  .al-flow-arrow--loop {
    font-size: 0.6875rem;
    color: #94a3b8;
    font-style: italic;
  }

  .al-flow-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    border-radius: 6px;
    padding: 0.375rem 0.625rem;
    font-size: 0.6875rem;
    min-width: 56px;
  }

  .al-flow-node--image {
    border: 1.5px dashed #cbd5e1;
    background: #f8fafc;
  }

  .al-flow-node--upload {
    border: 1.5px dashed #93c5fd;
    background: #eff6ff;
  }

  .al-flow-node--analyze {
    border: none;
    background: transparent;
  }

  .al-flow-node--results {
    border: 1.5px solid #e2e8f0;
    background: #ffffff;
    min-width: 52px;
    padding: 0.375rem 0.5rem;
    gap: 0.2rem;
  }

  .al-flow-node--question {
    border: 1.5px solid #e2e8f0;
    background: #fafafa;
    max-width: 110px;
  }

  .al-flow-node--copy {
    border: none;
    background: transparent;
  }

  .al-flow-node-top {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
  }

  .al-flow-node-zone {
    font-size: 0.625rem;
    color: #93c5fd;
    font-weight: 500;
  }

  .al-flow-node-btn {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #ffffff;
    background: #16a34a;
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }

  .al-flow-node-btn--copy {
    background: #475569;
  }

  .al-flow-node-line {
    display: block;
    height: 4px;
    width: 100%;
    background: #e2e8f0;
    border-radius: 2px;
  }

  .al-flow-node-line--short {
    width: 60%;
  }

  .al-flow-node-input {
    font-size: 0.6rem;
    color: #64748b;
    font-style: italic;
    text-align: center;
    line-height: 1.3;
  }

  /* ── Try Me ────────────────────────────────── */
  .al-try-me {
    margin: 1.25rem 0 0.75rem;
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
  }

  .al-try-me-btn {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: center;
    gap: 0.75rem;
    flex: 1;
