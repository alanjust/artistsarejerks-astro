---
import HiddenGrammarLayout from '../layouts/HiddenGrammarLayout.astro';

const sections = [
  {
    id: 'toolkit',
    label: 'Analysis Tools',
    title: 'Toolkit',
    description: "The primary way to use Art Lab. Pick what you're trying to do — making, analyzing, teaching, or stress-testing — and find the right tool for it.",
    status: 'live',
    href: '/hidden-grammar/toolkit',
    cta: 'Open the Toolkit →',
  },
  {
    id: 'framework',
    label: 'Framework',
    title: 'Hidden Grammar Framework',
    description: 'The structural system behind the analysis — what the 11 Roots, 54 Principles, and the two structural axes are, how they connect, and why the framework is built this way.',
    status: 'live',
    href: '/hidden-grammar/framework',
    cta: 'Explore the Framework →',
  },
  {
    id: 'roots',
    label: 'Framework',
    title: '11 Hidden Grammar Roots',
    description: 'The structural categories that organize all 54 Principles. Design Logic, Tactile Execution, Structural Integrity, Atmosphere, and seven more.',
    status: 'coming-soon',
    href: '/hidden-grammar/roots',
    cta: 'Explore the Roots →',
  },
  {
    id: 'principles',
    label: 'Framework',
    title: '54 Art Principles',
    description: 'The complete inventory of perceptual and compositional mechanisms the framework uses. Each Principle maps to a Root and a neural mechanism.',
    status: 'live',
    href: '/hidden-grammar/principles',
    cta: 'Browse the Principles →',
  },
  {
    id: 'poles',
    label: 'Reference',
    title: 'Basquiat Holds. Kinkade Resolves.',
    description: 'Two structural decisions every work makes: whether it holds or resolves, and how close it stays to the visible world.',
    status: 'live',
    href: '/hidden-grammar/poles',
    cta: 'See the Two Axes →',
  },
  {
    id: 'slam-read',
    label: 'Experimental',
    title: 'Slam Read',
    description: 'Upload a work. Get a performance back. No structure. No hedging. What the work does to a body.',
    status: 'live',
    href: '/hidden-grammar/modes/slam-read',
    cta: 'Read the Work →',
  },
  {
    id: 'lenses',
    label: 'External Frameworks',
    title: 'Interrogation Lenses',
    description: '24 critical and philosophical frameworks — from Object-Oriented Ontology to Hauntology — applied as analytical overlays on any analysis.',
    status: 'live',
    href: '/hidden-grammar/lenses',
    cta: 'Browse the Lenses →',
  },
  {
    id: 'reference',
    label: 'Reference',
    title: 'Reference Materials',
    description: "The Feldman Four-Step Critique, Visual Arts Standards, and the Master Project Bible. Foundational documents the framework builds on.",
    status: 'coming-soon',
    href: '/hidden-grammar/reference',
    cta: 'Open Reference →',
  },
];
---

<HiddenGrammarLayout
  title="Art Lab"
  description="Structured tools for looking at art — grounded in what's visually observable, not in what the art world has decided it means."
>
  <div class="hg-page">

    <!-- ── TOP: INTRO + SIDEBAR ────────────────────────────── -->
    <div class="al-body">

      <!-- Left: intro content -->
      <div class="al-intro">
        <h1 class="al-intro-title">Art Lab</h1>

        <p class="al-intro-kicker">Tools for looking at art.</p>

        <div class="al-try-me">
          <a href="/hidden-grammar/ai-analyze?mode=first-look&prompt=first-look-read" class="al-try-me-btn">
            <span class="al-try-me-label">Try Me</span>
            <span class="al-try-me-sub">upload anything</span>
          </a>
        </div>

        <p class="al-map-note"><strong>Digital Image Upload Considerations:</strong> <em class="al-map-note-body">Remember, you are uploading a digital image, not the actual artwork. The analysis is real, but some details will be lost.</em></p>

        <!-- Sample output excerpt -->
        <div class="al-excerpt">
          <div class="al-excerpt-label">
            <span class="al-excerpt-tag">Example Output</span>
            <span class="al-excerpt-meta">First Look—<em>The Starry Night</em>, Van Gogh, 1889</span>
          </div>
          <div class="al-excerpt-box">
            <p class="al-excerpt-text">Your eye doesn't choose where to go first. Something in the upper right just <em>takes</em> it—that luminous yellow disk, ringed in concentric halos, radiating against the deepest blue in the composition. You didn't decide to look there. And here's the thing: that moment of capture, where high-saturation warm color punches out of a cool-dominant field, isn't aesthetic preference. It's a hardwired color opponent channel firing before conscious attention even assembles. Warm against cool, light against dark, circular against directional—the moon wins the bid automatically.</p>
            <div class="al-excerpt-fade"></div>
          </div>
          <p class="al-excerpt-caption">This is what comes back.</p>
        </div>

        <div class="al-section-rule"></div>

        <a href="/hidden-grammar/start" class="al-start-btn">
          <span class="al-start-label">Start Analyzing</span>
        </a>
        <p class="al-start-sub">Picks a tool based on what you're trying to do—making, analyzing, teaching, or stress-testing.</p>

        <div class="al-section-rule"></div>

        <!-- Field guide -->
        <p class="al-intro-body">Think about the last time something stopped you. A painting in a museum, a sculpture you had to walk around twice, an illustration on a book cover that made you pick it up. Something happened in the first second. You just don't know what.</p>

        <p class="al-intro-body">That's the question Art Lab is built to answer.</p>

        <p class="al-intro-body">Upload an image — yours, someone else's, something you photographed and couldn't shake — and what comes back isn't interpretation. It's a structural read of what the work is actually doing to the eye in the first seconds of contact. Which edges are pulling attention. Where the eye moves and where it stalls. What the visual system is predicting, and whether the work confirms or violates that prediction.</p>

        <p class="al-intro-body">So here's what that looks like in practice. A painter finds out why the eye keeps going to the wrong corner. A ceramicist discovers what the surface and form are signaling before anyone decides what to think about it. An illustrator learns whether the visual register is landing the way they intend.</p>

        <p class="al-intro-body">The framework running underneath all of this is called Hidden Grammar — fifty-four perceptual mechanisms describing how visual communication works at the level of the nervous system, before culture, before taste, before any of the interpretive frameworks we usually reach for. The tools run that framework against whatever you put in front of them.</p>

        <p class="al-intro-body">What comes back is usually surprising.</p>

        <p class="al-intro-body">There are tools here for understanding what your work is doing visually, where it sits in the market, and how it lands on the people looking at it.</p>

        <div class="al-section-rule"></div>



      </div>

      <!-- Right: sidebar -->
      <aside class="al-sidebar">

        <div class="al-sidebar-card al-sidebar-reading">
          <h2 class="al-sidebar-card-title">Reading</h2>
          <ul class="al-reading-list">
            <li><a href="/hidden-grammar/why" class="al-reading-link">Why I built this</a></li>
            <li><a href="/hidden-grammar/keeping-score" class="al-reading-link">A different way to keep score</a></li>
            <li><a href="/hidden-grammar/grammar" class="al-reading-link">The grammar of visual art</a></li>
          </ul>
        </div>

      </aside>

    </div>

    <!-- ── SECTION CARDS — full width below ──────────────── -->
    <div class="al-sections">
      <div class="al-sections-header">
        <h2 class="al-sections-title">What's in Art Lab</h2>
      </div>
      <div class="hg-grid al-sections-grid">
        {sections.map(section => (
          section.status === 'live' ? (
            <a href={section.href} class="hg-card al-section-card">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span></span>
                <span class="al-card-arrow">→</span>
              </div>
            </a>
          ) : (
            <div class="hg-card al-section-card al-section-card--soon">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
                <span class="al-badge-soon">Coming soon</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span class="al-card-arrow-soon">{section.cta}</span>
              </div>
            </div>
          )
        ))}
      </div>
    </div>

  </div>
</HiddenGrammarLayout>

<style>
  /* ── CSS tokens for WorkflowInfographic ────── */
  .hg-page {
    --color-text-primary:       #0f172a;
    --color-text-secondary:     #64748b;
    --color-text-tertiary:      #94a3b8;
    --color-text-info:          #2563eb;
    --color-background-primary: #ffffff;
    --color-background-secondary: #f8fafc;
    --color-background-info:    #eff6ff;
    --color-border-primary:     #e2e8f0;
    --color-border-secondary:   #cbd5e1;
    --color-border-tertiary:    #f1f5f9;
    --color-border-info:        #93c5fd;
    --font-mono:                ui-monospace, 'Cascadia Code', monospace;
    --font-serif:               Georgia, serif;
    --border-radius-lg:         12px;
  }

  /* ── Two-column top: intro + sidebar ──────── */
  .al-body {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  /* ── Intro (left column) ───────────────────── */
  .al-intro {
    min-width: 0;
  }

  .al-intro-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .al-intro-kicker {
    font-size: 1.25rem;
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #b45309;
    line-height: 1.6;
    margin: 0 0 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .al-intro-body {
    font-size: 1.0625rem;
    color: #334155;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .al-text-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .al-text-link:hover {
    text-decoration: underline;
  }

  /* ── Sample output excerpt ───────────────────── */
  .al-excerpt {
    margin: 1.25rem 0 0.75rem;
  }

  .al-excerpt-label {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 0.5rem;
  }

  .al-excerpt-tag {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #b45309;
  }

  .al-excerpt-meta {
    font-size: 0.8125rem;
    color: #b45309;
    font-weight: 400;
  }

  .al-excerpt-box {
    position: relative;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow: hidden;
  }

  .al-excerpt-text {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #334155;
    margin: 0;
    font-style: italic;
  }

  .al-excerpt-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3rem;
    background: linear-gradient(to bottom, transparent, #f8fafc);
    pointer-events: none;
  }

  .al-excerpt-caption {
    font-size: 0.8125rem;
    color: #b45309;
    margin: 0.5rem 0 0;
    font-style: italic;
  }

  /* ── Try Me ────────────────────────────────── */
  .al-try-me {
    margin: 1.25rem 0 0.75rem;
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
  }

  .al-try-me-btn {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex: 1;
    padding: 1rem 2rem;
    background: #16a34a;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .al-try-me-btn:hover {
    background: #15803d;
    transform: translateY(-1px);
  }

  .al-try-me-label {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .al-try-me-sub {
    font-size: 1rem;
    font-weight: 500;
    color: #bbf7d0;
    letter-spacing: 0.01em;
  }

  .al-start-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    margin-bottom: 1.5rem;
    padding: 1rem 2rem;
    background: transparent;
    border: 2px solid #16a34a;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .al-start-btn:hover {
    background: #f0fdf4;
    transform: translateY(-1px);
  }

  .al-start-label {
    font-size: 1.25rem;
    font-weight: 700;
    color: #16a34a;
    letter-spacing: -0.01em;
  }

  .al-start-sub {
    font-size: 0.8125rem;
    color: #94a3b8;
    text-align: center;
    margin: 0.5rem 0 0;
    line-height: 1.5;
  }

  .al-section-rule {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }

  /* ── Map note ──────────────────────────────── */
  .al-map-note {
    font-size: 0.75rem;
    font-weight: 400;
    color: #94a3b8;
    line-height: 1.5;
    margin: 0.5rem 0 0.75rem;
  }

  .al-map-note-body {
    font-weight: 400;
  }

  /* ── Persona cards ─────────────────────────── */
  .al-personas {
    margin-top: 2.5rem;
  }

  .al-personas-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.375rem;
  }

  .al-personas-intro {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .al-persona-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .al-persona-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1.25rem 1.375rem;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    background: #ffffff;
  }

  .al-persona-card:hover {
    border-color: #94a3b8;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .al-persona-card--artist  { border-left: 3px solid #7c3aed; }
  .al-persona-card--edu     { border-left: 3px solid #059669; }
  .al-persona-card--curious { border-left: 3px solid #d97706; }

  .al-persona-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
  }

  .al-persona-card--artist  .al-persona-label { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-label { color: #047857; }
  .al-persona-card--curious .al-persona-label { color: #b45309; }

  .al-persona-body {
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .al-persona-body:last-of-type {
    margin-bottom: 0.875rem;
  }

  .al-persona-cta {
    font-size: 0.875rem;
    font-weight: 600;
    align-self: flex-start;
  }

  .al-persona-card--artist  .al-persona-cta { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-cta { color: #047857; }
  .al-persona-card--curious .al-persona-cta { color: #b45309; }

  /* ── Caution ───────────────────────────────── */
  .al-caution {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid #f59e0b;
    border-radius: 0 10px 10px 0;
  }

  .al-caution-title {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #92400e;
    margin: 0 0 0.875rem;
  }

  .al-caution-body {
    font-size: 0.9375rem;
    color: #78350f;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }

  .al-caution-link {
    color: #92400e;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .al-caution-link:hover {
    text-decoration: underline;
  }

  .al-caution-kicker {
    font-size: 0.9375rem;
    font-weight: 700;
    font-style: italic;
    color: #92400e;
    margin: 0;
  }

  /* ── Sidebar (right column) ────────────────── */
  .al-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .al-sidebar-card {
    border-radius: 10px;
    padding: 1.25rem 1.375rem;
  }

  .al-sidebar-card-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.875rem;
  }

  .al-sidebar-reading {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }

  .al-reading-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .al-reading-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #4f46e5;
    text-decoration: none;
    line-height: 1.4;
  }

  .al-reading-link:hover {
    text-decoration: underline;
  }

  /* ── Section cards — full width ────────────── */
  .al-sections {
    width: 100%;
  }

  .al-sections-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .al-sections-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .al-sections-grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .al-section-card {
    min-height: 200px;
  }

  .al-section-card--soon {
    opacity: 0.75;
    pointer-events: none;
  }

  .al-section-card--soon:hover {
    border-color: #e2e8f0;
    box-shadow: none;
    transform: none;
  }

  .al-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .al-badge-soon {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .al-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
  }

  .al-card-arrow {
    font-size: 0.875rem;
    color: #4f46e5;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    transform: translateX(-4px);
  }

  .hg-card:hover .al-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .al-card-arrow-soon {
    font-size: 0.875rem;
    font-weight: 600;
    color: #94a3b8;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .al-body {
      grid-template-columns: 1fr;
    }

    .al-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .al-sidebar-card {
      flex: 1 1 280px;
    }

    /* Tablet: tighten vertical rhythm */
    .al-intro-body {
      line-height: 1.7;
      margin-bottom: 0.75rem;
    }

    .al-section-rule {
      margin: 1.5rem 0;
    }

    .al-try-me {
      margin: 1rem 0 0.5rem;
    }

    .al-excerpt {
      margin: 0.75rem 0 0.5rem;
    }

    .al-start-btn {
      margin-bottom: 1rem;
    }

    /* Tablet: 2-up persona cards */
    .al-persona-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .al-intro-title {
      margin-bottom: 0.5rem;
    }

    .al-intro-kicker {
      line-height: 1.3;
      margin-bottom: 0.625rem;
      padding-bottom: 0.625rem;
    }

    .al-intro-body {
      line-height: 1.65;
      margin-bottom: 0.625rem;
    }

    .al-section-rule {
      margin: 1.25rem 0;
    }

    .al-try-me {
      margin: 0.75rem 0 0.375rem;
    }

    .al-excerpt {
      margin: 0.625rem 0 0.375rem;
    }

    .al-excerpt-box {
      padding: 1rem 1.125rem;
    }

    .al-start-btn {
      margin-bottom: 0.75rem;
    }

    .al-map-note {
      margin: 0.375rem 0 0.5rem;
    }

    .al-sections-grid {
      grid-template-columns: 1fr;
    }

    .al-caution {
      padding: 1.25rem;
    }

    .al-sidebar {
      flex-direction: column;
    }

    /* Mobile: single column persona cards */
    .al-persona-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
