---
import HiddenGrammarLayout from '../layouts/HiddenGrammarLayout.astro';

const sections = [
  {
    id: 'toolkit',
    label: 'Analysis Tools',
    title: 'Toolkit',
    description: "The primary way to use Art Lab. Pick what you're trying to do — making, analyzing, teaching, or stress-testing — and find the right tool for it.",
    status: 'live',
    href: '/hidden-grammar/toolkit',
    cta: 'Open the Toolkit →',
  },
  {
    id: 'framework',
    label: 'Framework',
    title: 'Hidden Grammar Framework',
    description: 'The structural system behind the analysis — what the 11 Roots, 54 Principles, and 4 Poles are, how they connect, and why the framework is built this way.',
    status: 'live',
    href: '/hidden-grammar/framework',
    cta: 'Explore the Framework →',
  },
  {
    id: 'roots',
    label: 'Framework',
    title: '11 Hidden Grammar Roots',
    description: 'The structural categories that organize all 54 Principles. Design Logic, Tactile Execution, Structural Integrity, Atmosphere, and seven more.',
    status: 'coming-soon',
    href: '/hidden-grammar/roots',
    cta: 'Explore the Roots →',
  },
  {
    id: 'principles',
    label: 'Framework',
    title: '54 Art Principles',
    description: 'The complete inventory of perceptual and compositional mechanisms the framework uses. Each Principle maps to a Root and a neural mechanism.',
    status: 'live',
    href: '/hidden-grammar/principles',
    cta: 'Browse the Principles →',
  },
  {
    id: 'poles',
    label: 'Framework',
    title: 'The 4 Poles',
    description: 'The four opposing forces that create visual tension in any work. Understanding the Poles tells you where a work sits on each axis.',
    status: 'coming-soon',
    href: '/hidden-grammar/poles',
    cta: 'See the Poles →',
  },
  {
    id: 'lenses',
    label: 'External Frameworks',
    title: 'Interrogation Lenses',
    description: '24 critical and philosophical frameworks — from Object-Oriented Ontology to Hauntology — applied as analytical overlays on any analysis.',
    status: 'live',
    href: '/hidden-grammar/lenses',
    cta: 'Browse the Lenses →',
  },
  {
    id: 'reference',
    label: 'Reference',
    title: 'Reference Materials',
    description: "The Feldman Four-Step Critique, Visual Arts Standards, and the Master Project Bible. Foundational documents the framework builds on.",
    status: 'coming-soon',
    href: '/hidden-grammar/reference',
    cta: 'Open Reference →',
  },
];
---

<HiddenGrammarLayout
  title="Art Lab"
  description="Structured tools for looking at art — grounded in what's visually observable, not in what the art world has decided it means."
>
  <div class="hg-page">

    <!-- ── TOP: INTRO + SIDEBAR ────────────────────────────── -->
    <div class="al-body">

      <!-- Left: intro content -->
      <div class="al-intro">
        <h1 class="al-intro-title">Art Lab</h1>

        <p class="al-intro-kicker">Tools for looking at art. Starting with what you can actually see.</p>

        <div class="al-try-me">
          <a href="/hidden-grammar/ai-analyze?mode=first-look&prompt=first-look-read" class="al-try-me-btn">
            <span class="al-try-me-label">Try Me</span>
            <span class="al-try-me-sub">upload anything</span>
          </a>
        </div>

        <p class="al-map-note">You're uploading a photo. The physical work of the original—its scale, surface, and material weight—doesn't come through. The analysis is real, but it's working from a reduced signal. A map, not the territory.</p>

        <!-- Personas -->
        <div class="al-personas">
          <h2 class="al-personas-title">What are you here to do?</h2>
          <p class="al-personas-intro">Pick the one that fits. Each path surfaces the tools most useful for where you are.</p>

          <div class="al-persona-cards">

            <a href="/hidden-grammar/for/artist" class="al-persona-card al-persona-card--artist">
              <span class="al-persona-label">Working artist</span>
              <p class="al-persona-body">You're mid-process, or you just finished something, and you want to know what it's actually doing — not what it means, but what it's doing. Where the eye goes. What's holding and what's sliding past.</p>
              <p class="al-persona-body">That's a different question than most feedback gives you. Art Lab is built around it.</p>
              <span class="al-persona-cta">Show me the studio tools →</span>
            </a>

            <a href="/hidden-grammar/for/curious" class="al-persona-card al-persona-card--curious">
              <span class="al-persona-label">Just curious</span>
              <p class="al-persona-body">You don't need a reason. You saw something—in a museum, online, somewhere—and it did something to you, and you want to know what.</p>
              <p class="al-persona-body">Or you made something just for the pleasure of it, and you're curious what it's actually doing.</p>
              <p class="al-persona-body">No agenda required. Start here and see what comes back.</p>
              <span class="al-persona-cta">Browse the tools →</span>
            </a>

            <a href="/hidden-grammar/for/educator" class="al-persona-card al-persona-card--edu">
              <span class="al-persona-label">Educator, docent, presenter</span>
              <p class="al-persona-body">You're standing in front of a work — or you will be, next Thursday, with a group of people who didn't necessarily choose to be there. You need something concrete to point at. Not interpretation. Not art-speak. Something you can actually say.</p>
              <p class="al-persona-body">There are tools here built specifically for that.</p>
              <span class="al-persona-cta">Show me the teaching tools →</span>
            </a>

          </div>
        </div>

        <div class="al-section-rule"></div>

        <!-- Origin story -->
        <p class="al-intro-body">Here's a thing that happens. You're standing in front of a painting—or you've just finished one—and something is either happening or it isn't. A pull. A restlessness. Or just nothing: the work sitting there, inert.</p>

        <p class="al-intro-body">And the language that comes back to you, from critics or teachers or your own internal monologue, is always about meaning. What the work represents. What the artist intended. What it says about the culture or the moment or the painter's biography.</p>

        <p class="al-intro-body">That language can't tell you why something stopped you cold. It can't tell you why something that should be working isn't. Those aren't interpretation problems. They're visual problems—perceptual problems—happening at a level below meaning, before anyone has decided what the work is about.</p>

        <p class="al-intro-body">Art Lab starts earlier in that sequence. Upload an image—yours, someone else's, something you photographed and couldn't shake—and what comes back is a read of the observable mechanics. Where attention goes first, and why. What's creating tension and what's releasing it. Which decisions are doing the work and which ones are coasting.</p>

        <p class="al-intro-body">It doesn't tell you what the painting means. It shows you what it's doing.</p>

        <a href="/hidden-grammar/why" class="al-text-link">Why I built this →</a>

        <!-- Art world + brain flags -->
        <div class="al-section-rule"></div>
        <p class="al-intro-body">The art world measures success by price and placement. Which galleries, which critics, which biennials. Art Lab runs on a different measure: whether someone stops in front of your work long enough for something to happen to them.</p>

        <p class="al-intro-body">That's not random. It's not taste. It comes down to specific, nameable visual decisions—decisions that land on the nervous system before the viewer has formed a single thought about the work. Before meaning. Before judgment. Before they've decided whether they're the kind of person who gets art.</p>

        <p class="al-intro-body">Those decisions are learnable. That's what this is for.</p>

        <a href="/hidden-grammar/grammar" class="al-text-link">How the visual grammar works →</a>

        <!-- Caution -->
        <div class="al-caution">
          <h2 class="al-caution-title">One thing before you pick a tool</h2>
          <p class="al-caution-body">Art Lab makes things legible that were previously invisible. That's useful. It can also, if you're not careful, turn creating into a performance review.</p>
          <p class="al-caution-body">If you're here to see your choices more clearly—to tighten, strengthen, understand what's working—it's for you. But if creating is mostly about pleasure or flow or finding your way, be careful. Once you start measuring, it's hard to stop. The measuring can become the point.</p>
          <p class="al-caution-body">Some artists will call this reductive. They're not wrong—any analysis reduces a work. The question is whether what remains after the reduction is useful to you.</p>
          <a href="/hidden-grammar/analysis-worth" class="al-text-link al-caution-link">Does analysis destroy an artwork? The full answer →</a>
          <p class="al-caution-kicker">Know what you came for.</p>
        </div>

      </div>

      <!-- Right: sidebar -->
      <aside class="al-sidebar">

        <div class="al-sidebar-card al-sidebar-reading">
          <h2 class="al-sidebar-card-title">Reading</h2>
          <ul class="al-reading-list">
            <li><a href="/hidden-grammar/why" class="al-reading-link">Why I built this</a></li>
          </ul>
        </div>

      </aside>

    </div>

    <!-- ── SECTION CARDS — full width below ──────────────── -->
    <div class="al-sections">
      <div class="al-sections-header">
        <h2 class="al-sections-title">What's in Art Lab</h2>
      </div>
      <div class="hg-grid al-sections-grid">
        {sections.map(section => (
          section.status === 'live' ? (
            <a href={section.href} class="hg-card al-section-card">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span></span>
                <span class="al-card-arrow">→</span>
              </div>
            </a>
          ) : (
            <div class="hg-card al-section-card al-section-card--soon">
              <div class="al-card-top">
                <span class="hg-card-label">{section.label}</span>
                <span class="al-badge-soon">Coming soon</span>
              </div>
              <h3 class="hg-card-title">{section.title}</h3>
              <p class="hg-card-desc">{section.description}</p>
              <div class="al-card-footer">
                <span class="al-card-arrow-soon">{section.cta}</span>
              </div>
            </div>
          )
        ))}
      </div>
    </div>

  </div>
</HiddenGrammarLayout>

<style>
  /* ── Two-column top: intro + sidebar ──────── */
  .al-body {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  /* ── Intro (left column) ───────────────────── */
  .al-intro {
    min-width: 0;
  }

  .al-intro-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #0f172a;
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .al-intro-kicker {
    font-size: 1.25rem;
    font-weight: 600;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #b45309;
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .al-intro-body {
    font-size: 1.0625rem;
    color: #334155;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .al-text-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .al-text-link:hover {
    text-decoration: underline;
  }

  /* ── Try Me ────────────────────────────────── */
  .al-try-me {
    margin: 1.25rem 0 0.75rem;
  }

  .al-try-me-btn {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 2rem;
    background: #16a34a;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .al-try-me-btn:hover {
    background: #15803d;
    transform: translateY(-1px);
  }

  .al-try-me-label {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .al-try-me-sub {
    font-size: 1rem;
    font-weight: 500;
    color: #bbf7d0;
    letter-spacing: 0.01em;
  }

  .al-section-rule {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }

  /* ── Map note ──────────────────────────────── */
  .al-map-note {
    font-size: 1.0rem;
    font-weight: 500;
    font-style: italic;
    color: #16a34a;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  /* ── Persona cards ─────────────────────────── */
  .al-personas {
    margin-top: 2.5rem;
  }

  .al-personas-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.375rem;
  }

  .al-personas-intro {
    font-size: 0.9375rem;
    color: #64748b;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .al-persona-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .al-persona-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1.25rem 1.375rem;
    border-radius: 10px;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    background: #ffffff;
  }

  .al-persona-card:hover {
    border-color: #94a3b8;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .al-persona-card--artist  { border-left: 3px solid #7c3aed; }
  .al-persona-card--edu     { border-left: 3px solid #059669; }
  .al-persona-card--curious { border-left: 3px solid #d97706; }

  .al-persona-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
  }

  .al-persona-card--artist  .al-persona-label { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-label { color: #047857; }
  .al-persona-card--curious .al-persona-label { color: #b45309; }

  .al-persona-body {
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .al-persona-body:last-of-type {
    margin-bottom: 0.875rem;
  }

  .al-persona-cta {
    font-size: 0.875rem;
    font-weight: 600;
    align-self: flex-start;
  }

  .al-persona-card--artist  .al-persona-cta { color: #6d28d9; }
  .al-persona-card--edu     .al-persona-cta { color: #047857; }
  .al-persona-card--curious .al-persona-cta { color: #b45309; }

  /* ── Caution ───────────────────────────────── */
  .al-caution {
    margin-top: 2rem;
    padding: 1.5rem 1.75rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid #f59e0b;
    border-radius: 0 10px 10px 0;
  }

  .al-caution-title {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #92400e;
    margin: 0 0 0.875rem;
  }

  .al-caution-body {
    font-size: 0.9375rem;
    color: #78350f;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }

  .al-caution-link {
    color: #92400e;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .al-caution-link:hover {
    text-decoration: underline;
  }

  .al-caution-kicker {
    font-size: 0.9375rem;
    font-weight: 700;
    font-style: italic;
    color: #92400e;
    margin: 0;
  }

  /* ── Sidebar (right column) ────────────────── */
  .al-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .al-sidebar-card {
    border-radius: 10px;
    padding: 1.25rem 1.375rem;
  }

  .al-sidebar-card-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0 0 0.875rem;
  }

  .al-sidebar-reading {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
  }

  .al-reading-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .al-reading-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #4f46e5;
    text-decoration: none;
    line-height: 1.4;
  }

  .al-reading-link:hover {
    text-decoration: underline;
  }

  /* ── Section cards — full width ────────────── */
  .al-sections {
    width: 100%;
  }

  .al-sections-header {
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .al-sections-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .al-sections-grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .al-section-card {
    min-height: 200px;
  }

  .al-section-card--soon {
    opacity: 0.75;
    pointer-events: none;
  }

  .al-section-card--soon:hover {
    border-color: #e2e8f0;
    box-shadow: none;
    transform: none;
  }

  .al-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .al-badge-soon {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 0.175rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .al-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
  }

  .al-card-arrow {
    font-size: 0.875rem;
    color: #4f46e5;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    transform: translateX(-4px);
  }

  .hg-card:hover .al-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .al-card-arrow-soon {
    font-size: 0.875rem;
    font-weight: 600;
    color: #94a3b8;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .al-body {
      grid-template-columns: 1fr;
    }

    .al-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .al-sidebar-card {
      flex: 1 1 280px;
    }

    /* Tablet: 2-up persona cards */
    .al-persona-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .al-sections-grid {
      grid-template-columns: 1fr;
    }

    .al-caution {
      padding: 1.25rem;
    }

    .al-sidebar {
      flex-direction: column;
    }

    /* Mobile: single column persona cards */
    .al-persona-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
